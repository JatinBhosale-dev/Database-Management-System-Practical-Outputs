CREATE DATABASE UniversityDB;
USE UniversityDB;
CREATE TABLE Department ( DeptID INT PRIMARY KEY, DeptName VARCHAR(50) NOT NULL, HOD VARCHAR(50) );
CREATE TABLE Student ( RollNo INT PRIMARY KEY, Name VARCHAR(50) NOT NULL, Marks FLOAT, City VARCHAR(50), DeptID INT, FOREIGN KEY (DeptID) REFERENCES Department(DeptID) ON DELETE SET NULL ON UPDATE CASCADE );

SHOW TABLES;
DESCRIBE Student;
