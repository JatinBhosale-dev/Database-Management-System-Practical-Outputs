-- Create the Stored Procedure using Conditional Statements
CREATE PROCEDURE AssignGrade(IN p_RollNo INT)
BEGIN
    DECLARE v_Marks FLOAT;
    DECLARE v_Grade VARCHAR(20);

    -- Fetch the marks for the given student and store it in the variable
    SELECT Marks INTO v_Marks FROM StudentResult WHERE RollNo = p_RollNo;

    -- Apply Conditional Logic
    IF v_Marks >= 75.0 THEN
        SET v_Grade = 'Distinction';
    ELSEIF v_Marks >= 60.0 THEN
        SET v_Grade = 'First Class';
    ELSEIF v_Marks >= 40.0 THEN
        SET v_Grade = 'Pass';
    ELSE
        SET v_Grade = 'Fail';
    END IF;

    -- Update the student's record with the calculated grade
    UPDATE StudentResult SET Grade = v_Grade WHERE RollNo = p_RollNo;
END //

