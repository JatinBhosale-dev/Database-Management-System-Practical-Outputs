Creating the User-Defined Function
-- Change the delimiter from ; to //
DELIMITER //

-- Create the Function
CREATE FUNCTION CheckScholarship(student_marks FLOAT) 
RETURNS VARCHAR(15)
DETERMINISTIC
BEGIN
    -- Declare a variable to hold the result
    DECLARE eligibility_status VARCHAR(15);

    -- Conditional logic to determine the return value
    IF student_marks >= 85.0 THEN
        SET eligibility_status = 'Eligible';
    ELSE
        SET eligibility_status = 'Not Eligible';
    END IF;

    -- The function MUST return a value
    RETURN eligibility_status;
END //

-- Change the delimiter back to standard semicolon
DELIMITER ;

Verification (Using the Function)
-- Call the function inside a SELECT statement
SELECT RollNo, Name, Marks, CheckScholarship(Marks) AS Scholarship_Status FROM Student;

-- You can also use functions in the WHERE clause!
SELECT Name FROM Student WHERE CheckScholarship(Marks) = 'Eligible';

